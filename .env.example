# ─────────────────────────────────────────────────────
# PunxFilm OS — Environment Variables
# Copy this file to .env (dev) or configure on Railway (prod)
# ─────────────────────────────────────────────────────

# Database
# Dev: SQLite locale
DATABASE_URL="file:./dev.db"
# Prod Railway: fornita automaticamente da Railway Postgres
# DATABASE_URL="postgresql://user:password@host:5432/railway"

# Anthropic Claude API (per enrichment AI, matching, suggest-queue)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# NextAuth.js (Auth.js v5) — usati dalla Fase 2 in poi
# Generare con: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"
# Prod: https://your-app.up.railway.app

# Admin seeding (usato da prisma/seed.ts)
ADMIN_EMAIL="admin@punxfilm.it"
ADMIN_PASSWORD="change-me-strong-password"

# Resend (email alert deadline, Fase 6) — opzionale per MVP
# RESEND_API_KEY="re_..."
# RESEND_FROM="PunxFilm OS <noreply@punxfilm.it>"

# Sentry (error monitoring, Fase 7) — opzionale
# SENTRY_DSN="https://...ingest.sentry.io/..."

# Node environment
NODE_ENV="development"
